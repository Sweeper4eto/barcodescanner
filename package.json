{
  "name": "magazin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\"",
    "build": "node scripts/build.mjs",
    "start": "next start",
    "dev:lan": "node scripts/lan-https.mjs dev",
    "start:lan": "node scripts/lan-https.mjs start",
    "lint": "eslint",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:import-off": "tsx scripts/import-open-food-facts.ts",
    "db:import-off-rest": "tsx scripts/import-open-food-facts.ts --source rest --download --all",
    "db:populate-images": "tsx scripts/populate-product-images.ts",
    "db:clean-names": "tsx scripts/clean-product-names.ts",
    "db:refresh-names": "tsx scripts/refresh-product-names-from-dumps.ts",
    "db:fix-names-online": "tsx scripts/fix-names-from-internet.ts",
    "db:fix-images-online": "tsx scripts/fix-images-from-internet.ts",
    "icons": "node scripts/generate-icons.mjs",
    "vapid": "node scripts/generate-vapid-keys.mjs",
    "admin:password": "tsx scripts/set-admin-password.ts",
    "db:reset": "prisma migrate reset --force",
    "test": "tsx --test --test-concurrency=1 tests/**/*.test.ts",
    "test:e2e": "playwright test",
    "test:all": "npm run test && npm run test:e2e",
    "validate": "npm run lint && npm run test && npm run build"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@zxing/library": "^0.23.0",
    "barcode-detector": "^3.2.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.4.2",
    "html5-qrcode": "^2.3.8",
    "jose": "^6.2.3",
    "next": "16.2.9",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "web-push": "^3.6.7",
    "zod": "^4.4.3",
    "zxing-wasm": "^3.1.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/http-proxy": "^1.17.17",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "http-proxy": "^1.18.1",
    "selfsigned": "^5.5.0",
    "sharp": "^0.35.2",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
