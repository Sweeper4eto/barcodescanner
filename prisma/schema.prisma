generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  ADMIN
  USER
}

enum ClientRole {
  OWNER
  MEMBER
}

model User {
  id           String      @id @default(cuid())
  username     String      @unique
  passwordHash String
  role         Role        @default(USER)
  /// OWNER can manage team members for their client; MEMBER is regular access.
  clientRole   ClientRole?
  active       Boolean     @default(true)
  clientId     String?
  client       Client?     @relation(fields: [clientId], references: [id], onDelete: SetNull)
  storeLinks   UserStore[]
  pushSubscriptions PushSubscription[]
  pushNotificationLogs PushNotificationLog[]
  auditLogs         AuditLog[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([clientId])
}

model Client {
  id                 String    @id @default(cuid())
  name               String
  phone              String?
  additionalInfo     String?
  active             Boolean   @default(true)
  homeUser           Boolean   @default(false)
  monthlyFeePerStore Float     @default(20)
  users              User[]
  stores             Store[]
  payments           Payment[]
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model Store {
  id             String           @id @default(cuid())
  clientId       String
  client         Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name           String
  address        String?
  phone          String?
  additionalInfo String?
  active         Boolean          @default(true)
  userLinks      UserStore[]
  inventory      InventoryEntry[]
  buyList        BuyListEntry[]
  favourites     FavouriteProduct[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([clientId])
}

model UserStore {
  userId  String
  storeId String
  user    User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  store   Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@id([userId, storeId])
}

model Product {
  id        String           @id @default(cuid())
  barcode   String           @unique
  name      String
  imagePath String?
  inventory InventoryEntry[]
  buyList   BuyListEntry[]
  favourites FavouriteProduct[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([name])
}

model InventoryEntry {
  id         String    @id @default(cuid())
  storeId    String
  store      Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  productId  String
  product    Product   @relation(fields: [productId], references: [id], onDelete: Restrict)
  barcode    String
  articul    String?
  imagePath  String?
  quantity   Int
  expiryDate DateTime
  enteredAt  DateTime  @default(now())
  removedAt  DateTime?
  priceReducedAt DateTime?
  deletedAt  DateTime?

  @@index([storeId, expiryDate])
  @@index([storeId, removedAt, deletedAt])
}

model FavouriteProduct {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([storeId, productId])
  @@index([storeId])
}

model BuyListEntry {
  id        String    @id @default(cuid())
  storeId   String
  store     Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  productId String
  product   Product   @relation(fields: [productId], references: [id], onDelete: Restrict)
  barcode   String
  quantity  Int
  enteredAt DateTime  @default(now())
  removedAt DateTime?

  @@index([storeId, removedAt])
}

model Payment {
  id               String   @id @default(cuid())
  clientId         String
  client           Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  year             Int
  month            Int
  activeStoreCount Int
  feePerStore      Float
  discount         Float    @default(0)
  amountPaid       Float
  paidAt           DateTime @default(now())
  notes            String?

  @@unique([clientId, year, month])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  locale    String   @default("en")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model PushNotificationLog {
  id     String   @id @default(cuid())
  userId String
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind   String
  sentAt DateTime @default(now())

  @@index([userId, kind, sentAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  username   String
  event      String
  ipAddress  String   @default("")
  deviceInfo String   @default("")
  details    String   @default("")
  occurredAt DateTime @default(now())

  @@index([occurredAt])
  @@index([event])
  @@index([username])
}
